digraph BellmanBackupTaxonomy {
  graph [
    rankdir=TB,
    bgcolor="transparent",
    pad="0.25",
    nodesep="0.4",
    ranksep="0.55"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    margin="0.18,0.12",
    color="#334155",
    fillcolor="#f8fafc"
  ];
  edge [
    fontname="Helvetica",
    fontsize=11,
    arrowsize=0.75,
    penwidth=2.0,
    color="#2563eb"
  ];

  bellman [label=<
    <B>Bellman backups</B><BR/>
    one-step recursive targets
  >, fillcolor="#e0f2fe", color="#0284c7"];

  expectation [label=<
    <B>Expectation backup</B><BR/>
    average under policy &pi;
  >, fillcolor="#dbeafe", color="#1d4ed8"];

  optimality [label=<
    <B>Optimality backup</B><BR/>
    max over next actions
  >, fillcolor="#ede9fe", color="#7c3aed"];

  evaluation [label=<
    <B>Policy evaluation</B><BR/>
    estimate V<SUP>&pi;</SUP>, Q<SUP>&pi;</SUP>
  >, fillcolor="#eff6ff"];

  improvement [label=<
    <B>Policy improvement</B><BR/>
    greedy step from Q
  >, fillcolor="#fff7ed", color="#c77700"];

  control [label=<
    <B>Control algorithms</B><BR/>
    value iteration, Q-learning
  >, fillcolor="#fef3c7", color="#b45309"];

  bellman -> expectation;
  bellman -> optimality;
  expectation -> evaluation;
  evaluation -> improvement [label="greedy policy"];
  optimality -> control;
  improvement -> control [style=dashed, color="#94a3b8", label="repeat"];
}
