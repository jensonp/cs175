digraph PPOClip {
  graph [
    rankdir=LR,
    bgcolor="transparent",
    pad="0.25",
    nodesep="0.45",
    ranksep="0.7"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    margin="0.18,0.12",
    color="#334155",
    fillcolor="#f8fafc"
  ];
  edge [
    fontname="Helvetica",
    fontsize=11,
    arrowsize=0.75,
    penwidth=2.0,
    color="#2563eb"
  ];

  oldpolicy [label=<
    <B>Old policy</B><BR/>
    collect on-policy data
  >, fillcolor="#dbeafe", color="#1d4ed8"];
  ratio [label=<
    <B>Importance ratio</B><BR/>
    r<SUB>t</SUB>(&theta;) = &pi;<SUB>&theta;</SUB> / &pi;<SUB>old</SUB>
  >, fillcolor="#ede9fe", color="#7c3aed"];
  advantage [label=<
    <B>Advantage estimate</B><BR/>
    A-hat<SUB>t</SUB>
  >, fillcolor="#ecfccb", color="#4d7c0f"];
  unclipped [label=<
    <B>Unclipped objective</B><BR/>
    r<SUB>t</SUB>(&theta;) A-hat<SUB>t</SUB>
  >, fillcolor="#fff7ed", color="#c77700"];
  clipped [label=<
    <B>Clipped surrogate</B><BR/>
    limit policy drift
  >, fillcolor="#fef3c7", color="#b45309"];
  update [label=<
    <B>Conservative update</B><BR/>
    stable improvement
  >, fillcolor="#fce7f3", color="#be185d"];

  oldpolicy -> ratio;
  oldpolicy -> advantage;
  ratio -> unclipped;
  advantage -> unclipped;
  unclipped -> clipped;
  clipped -> update;
}
