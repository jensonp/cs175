digraph DeadlyTriad {
  graph [
    rankdir=TB,
    bgcolor="transparent",
    pad="0.25",
    nodesep="0.5",
    ranksep="0.6"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    margin="0.18,0.12",
    color="#334155",
    fillcolor="#f8fafc"
  ];
  edge [
    fontname="Helvetica",
    fontsize=11,
    arrowsize=0.75,
    penwidth=2.0,
    color="#2563eb"
  ];

  offpolicy [label=<
    <B>Off-policy learning</B><BR/>
    data from a different behavior policy
  >, fillcolor="#dbeafe", color="#2563eb"];
  bootstrap [label=<
    <B>Bootstrapping</B><BR/>
    targets depend on learned estimates
  >, fillcolor="#ede9fe", color="#7c3aed"];
  approximation [label=<
    <B>Function approximation</B><BR/>
    shared parameters couple many predictions
  >, fillcolor="#ecfccb", color="#4d7c0f"];
  instability [label=<
    <B>Instability risk</B><BR/>
    moving targets, divergence, overestimation
  >, fillcolor="#fee2e2", color="#dc2626"];

  offpolicy -> instability;
  bootstrap -> instability;
  approximation -> instability;
  offpolicy -> bootstrap [dir=both, arrowhead=none, arrowtail=none, style=dashed, color="#94a3b8"];
  bootstrap -> approximation [dir=both, arrowhead=none, arrowtail=none, style=dashed, color="#94a3b8"];
  approximation -> offpolicy [dir=both, arrowhead=none, arrowtail=none, style=dashed, color="#94a3b8"];
}
