digraph EvaluationWorkflow {
  graph [
    rankdir=LR,
    bgcolor="transparent",
    pad="0.25",
    nodesep="0.45",
    ranksep="0.75"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    margin="0.18,0.12",
    color="#334155",
    fillcolor="#f8fafc"
  ];
  edge [
    fontname="Helvetica",
    fontsize=11,
    arrowsize=0.75,
    penwidth=2.0,
    color="#2563eb"
  ];

  train [label=<
    <B>Train policy</B><BR/>
    often with exploration enabled
  >, fillcolor="#dbeafe", color="#1d4ed8"];
  checkpoint [label=<
    <B>Checkpoint model</B><BR/>
    fixed parameters for testing
  >, fillcolor="#ede9fe", color="#7c3aed"];
  eval [label=<
    <B>Evaluate policy</B><BR/>
    no training updates
  >, fillcolor="#fff7ed", color="#c77700"];
  seeds [label=<
    <B>Repeat across seeds</B><BR/>
    capture variability
  >, fillcolor="#ecfccb", color="#4d7c0f"];
  metrics [label=<
    <B>Aggregate metrics</B><BR/>
    mean, spread, sample and compute cost
  >, fillcolor="#fce7f3", color="#be185d"];

  train -> checkpoint -> eval -> seeds -> metrics;
}
